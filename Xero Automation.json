    {
      "parameters": {
        "jsCode": "const results = [];\n\n// Separate invoices and emails\nconst invoices = items.filter(item => item.json.invoiceId !== undefined);\nconst emails = items.filter(item => item.json.threadId !== undefined);\n\nfor (const email of emails) {\n  // Get email text content\n  const text = email.json.text || '';\n  const html = email.json.html || '';\n  const content = text + ' ' + html;\n\n  // Get binary attachments\n  const binaryKeys = Object.keys(email.binary || {});\n\n  // Find matching invoice\n  const matchedInvoice = invoices.find(inv => {\n    const vendorName = inv.json.vendorName || '';\n    const amount = String(inv.json.amount || '');\n    \n    return (\n      content.toLowerCase().includes(vendorName.toLowerCase()) &&\n      content.includes(amount)\n    );\n  });\n\n  if (!matchedInvoice) continue;\n\n  // If email has attachments\n  if (binaryKeys.length > 0) {\n    for (const key of binaryKeys) {\n      const file = email.binary[key];\n      results.push({\n        json: {\n          invoiceId: matchedInvoice.json.invoiceId,\n          vendorName: matchedInvoice.json.vendorName,\n          amount: matchedInvoice.json.amount,\n          date: matchedInvoice.json.date,\n          dueDate: matchedInvoice.json.dueDate,\n          accountCode: matchedInvoice.json.accountCode,\n          taxType: matchedInvoice.json.taxType,\n          currency: matchedInvoice.json.currency,\n          emailId: email.json.id,\n          emailSubject: email.json.subject,\n          fileName: file.fileName || 'attachment.pdf',\n          mimeType: file.mimeType || 'application/octet-stream'\n        },\n        binary: {\n          data: file\n        }\n      });\n    }\n  } else {\n    // No attachment but still matched\n    results.push({\n      json: {\n        invoiceId: matchedInvoice.json.invoiceId,\n        vendorName: matchedInvoice.json.vendorName,\n        amount: matchedInvoice.json.amount,\n        date: matchedInvoice.json.date,\n        dueDate: matchedInvoice.json.dueDate,\n        accountCode: matchedInvoice.json.accountCode,\n        taxType: matchedInvoice.json.taxType,\n        currency: matchedInvoice.json.currency,\n        emailId: email.json.id,\n        emailSubject: email.json.subject,\n        fileName: null,\n        mimeType: null\n      }\n    });\n  }\n}\n\nreturn results.length > 0 ? results : [{ json: { message: 'No matches found' } }];"
      },
