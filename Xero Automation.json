    {
      "parameters": {
        "jsCode": "const results = [];\n\n// Get all invoices from Invoice filter\nconst invoices = $('Invoice filter').all();\n\n// Get all matched emails from Gmail Filter\nconst matchedEmails = $('Gmail Filter2').all();\n\nfor (const invoice of invoices) {\n  const vendorName = invoice.json.vendorName || '';\n  const amount = invoice.json.amount || 0;\n  const invoiceId = invoice.json.invoiceId || '';\n  const date = invoice.json.date || '';\n\n  // Check if any email matches this invoice\n  const hasMatch = matchedEmails.some(email => {\n    const snippet = email.json.snippet || '';\n    const text = email.json.text || '';\n    const content = snippet + ' ' + text;\n    return (\n      content.toLowerCase().includes(vendorName.toLowerCase()) &&\n      content.includes(String(amount))\n    );\n  });\n\n  if (!hasMatch) {\n    results.push({\n      json: {\n        invoiceId: invoiceId,\n        vendorName: vendorName,\n        amount: amount,\n        date: date,\n        status: 'NO EMAIL FOUND',\n        loggedAt: new Date().toISOString()\n      }\n    });\n  }\n}\n\nreturn results.length > 0 ? results : [{ json: { message: 'All invoices matched' } }];"
      },
