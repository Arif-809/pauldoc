      "parameters": {
        "jsCode": "return items.map(item => {\n  // Access the nested Invoices object from the input\n  const inv = item.json.Invoices; \n\n  return {\n    json: {\n      invoiceId: inv.InvoiceID || \"\",\n      vendorName: inv.Contact?.Name || \"Unknown Vendor\",\n      amount: inv.Total || 0,\n      // Safely split the date string to remove the time portion\n      date: inv.DateString ? inv.DateString.split('T')[0] : \"\", \n      dueDate: inv.DueDateString ? inv.DueDateString.split('T')[0] : \"\",\n      // Pull account details from the first line item\n      accountCode: inv.LineItems?.[0]?.AccountCode || \"400\",\n      taxType: inv.LineItems?.[0]?.TaxType || \"NONE\",\n      currency: inv.CurrencyCode || \"BDT\"\n    }\n  };\n});"
