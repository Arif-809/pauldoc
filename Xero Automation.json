    {
      "parameters": {
        "jsCode": "const transactions = $input.first().json.BankTransactions;\n\nif (!transactions || transactions.length === 0) {\n  return [{ json: { subject: 'Daily Bank Summary - No Transactions', body: 'No transactions found for today.' } }];\n}\n\n// Separate RECEIVE and SPEND\nconst receives = transactions.filter(tx => tx.Type === 'RECEIVE');\nconst spends = transactions.filter(tx => tx.Type === 'SPEND');\n\n// Calculate totals\nconst totalIn = receives.reduce((sum, tx) => sum + tx.Total, 0);\nconst totalOut = spends.reduce((sum, tx) => sum + tx.Total, 0);\nconst net = totalIn - totalOut;\n\n// Format date\nconst today = new Date().toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });\n\n// Build RECEIVE section\nlet receiveLines = receives.length > 0\n  ? receives.map(tx => `  • ${tx.Contact?.Name || 'Unknown'}: £${tx.Total.toFixed(2)}`).join('\\n')\n  : '  None';\n\n// Build SPEND section\nlet spendLines = spends.length > 0\n  ? spends.map(tx => `  • ${tx.Contact?.Name || 'Unknown'}: £${tx.Total.toFixed(2)}`).join('\\n')\n  : '  None';\n\n// Build email body\nconst body = `📊 Daily Bank Summary - ${today}\n\n💰 MONEY IN (${receives.length} transactions):\n${receiveLines}\nTotal In: £${totalIn.toFixed(2)}\n\n💸 MONEY OUT (${spends.length} transactions):\n${spendLines}\nTotal Out: £${totalOut.toFixed(2)}\n\n${net >= 0 ? '✅' : '⚠️'} Net: ${net >= 0 ? '+' : ''}£${net.toFixed(2)}\n\n---\nGenerated automatically by n8n`;\n\nreturn [{\n  json: {\n    subject: `📊 Daily Bank Summary - ${today} | Net: ${net >= 0 ? '+' : ''}£${net.toFixed(2)}`,\n    body: body\n  }\n}];"
      },
