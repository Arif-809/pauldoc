              "leftValue": "={{ $('Invoice filter').all().some(item => {\n  const emailTime = Number($json.internalDate);\n  const invoiceTime = new Date(item.json.date).getTime();\n  \n  const diffDays = Math.abs((emailTime - invoiceTime) / 86400000);\n  const isWithinDate = diffDays <= 14;\n\n  const amount = item.json.amount.toString();\n  const amountDec = Number(item.json.amount).toFixed(2);\n  const hasAmount = $json.snippet.includes(amount) || $json.snippet.includes(amountDec);\n\n  const hasVendor = $json.snippet.toLowerCase().includes(item.json.vendorName.toLowerCase());\n\n  return (hasAmount && isWithinDate) || (hasVendor && hasAmount);\n}) }}",
